{
  "name": "squid-monorepo",
  "private": true,
  "workspaces": [
    "ui"
  ],
  "scripts": {
    "contracts:build": "forge build --root contracts",
    "contracts:test": "forge test --root contracts",
    "contracts:test:fork": "forge test --root contracts --match-path 'test/fork/*.t.sol' -vv",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:contracts:test": "docker compose run --rm contracts",
    "ui:dev": "npm --workspace ui run dev",
    "ui:build": "npm --workspace ui run build",
    "ui:lint": "npm --workspace ui run lint"
  }
}
